# Copy this file to .env.local for local development,
# and add the same keys in Vercel -> Project -> Settings -> Environment Variables for deployment.

# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# SurveyMonkey survey links (one per mode)
NEXT_PUBLIC_SURVEYMONKEY_URL_ADULT=
NEXT_PUBLIC_SURVEYMONKEY_URL_CHILDREN=

# ngrok tunnel base URL for the anonymization pipeline computer
# The app POSTs to `${NEXT_PUBLIC_NGROK_URL}/start`
NEXT_PUBLIC_NGROK_URL=

# Password for the /admin dashboard (server-side only, no NEXT_PUBLIC_ prefix)
ADMIN_PASSWORD=
